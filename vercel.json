{
  "functions": {
    "api/roadmap-copy.js": {
      "maxDuration": 30
    },
    "api/life-report.js": {
      "maxDuration": 30
    },
    "api/soccercard-track.js": {
      "maxDuration": 10
    }
  },
  "redirects": [
    {
      "source": "/projectmystery",
      "destination": "/projectmystery/",
      "permanent": true
    },
    {
      "source": "/notoast",
      "destination": "/notoast/",
      "permanent": true
    },
    {
      "source": "/soccercard",
      "destination": "/soccercard/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/projectmystery/api/context",
      "destination": "/api/context"
    },
    {
      "source": "/projectmystery/api/health",
      "destination": "/api/health"
    },
    {
      "source": "/projectmystery/api/roadmap-copy",
      "destination": "/api/roadmap-copy"
    },
    {
      "source": "/projectmystery/api/life-report",
      "destination": "/api/life-report"
    },
    {
      "source": "/projectmystery/",
      "destination": "/preview/life-roadmap-mvp/index.html"
    },
    {
      "source": "/projectmystery/:path*",
      "destination": "/preview/life-roadmap-mvp/:path*"
    },
    {
      "source": "/notoast/",
      "destination": "/preview/bujingjiu/index.html"
    },
    {
      "source": "/notoast/:path*",
      "destination": "/preview/bujingjiu/:path*"
    },
    {
      "source": "/soccercard/",
      "destination": "/preview/soccercard/index.html"
    },
    {
      "source": "/soccercard/api/track",
      "destination": "/api/soccercard-track"
    },
    {
      "source": "/soccercard/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/soccercard/library",
      "destination": "/preview/soccercard/index.html"
    },
    {
      "source": "/soccercard/library/",
      "destination": "/preview/soccercard/index.html"
    },
    {
      "source": "/soccercard/library/:path*",
      "destination": "/preview/soccercard/:path*"
    },
    {
      "source": "/soccercard/:path*",
      "destination": "/preview/soccercard/:path*"
    }
  ]
}
